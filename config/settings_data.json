      "custom-template3": {
        "type": "custom-template3",
        "blocks": {
          "643ebc0d-e11c-477c-83e2-1dcfb96f3475": {
            "type": "text",
            "settings": {
              "image": "shopify:\/\/shop_images\/custom-banner.png",
              "title": "<h3>We are Shopify experts. Need help growing your Shopify sales?<\/h3>",
              "text": "<p>We provide innovative solutions to expand your business. Let us take your online shop to new dimension in success! Boost your store sales and define your brands with Avone.<br\/><\/p>",
              "btntxt": "Read More",
              "width": "50%",
              "alignment": "top-middle",
              "align_text": "left"
            }
          },
          "4cc6c2ac-58b1-4e07-a382-7e301afab41f": {
            "type": "text",
            "settings": {
              "title": "",
              "text": "<p><strong>Design Quality<\/strong><\/p><p>First impressions of online store is 94% design related. Quality web design establishes trust and credibility. We provide high quality shopify themes. <br\/><br\/><br\/><strong>One Click Demo Installation<\/strong><\/p><p>It&#x27;s very easy to install the demo just by a single click. It’s totally automatic and save your time.<br\/><br\/><br\/><strong>Top Quality Documentation<br\/><\/strong><br\/>Extensive documentation where each section of the theme and its features are described in a easy way to understand.<\/p><p><br\/><\/p>",
              "btntxt": "Read More",
              "width": "25%",
              "alignment": "top-middle",
              "align_text": "left"
            }
          },
          "141afeac-4573-4d84-abf4-401f32de95a8": {
            "type": "text",
            "settings": {
              "title": "",
              "text": "<p><strong>Unlimited power and<br\/> customization possibilities<\/strong><\/p><p>Save time and frustration by visually editing your site. Build professional layouts in just a few minutes.<br\/><br\/><br\/><strong>High Speed &amp; Performance<\/strong><\/p><p>Performance matters the most for your online shop ! We leverage the strategy and help you earn maximum ROI.<br\/><br\/><br\/><strong>Top Notch Support <\/strong><\/p><p>Get the best technical support in 24 hours. If you have questions or problems, we are glad to help you<\/p>",
              "btntxt": "Read More",
              "width": "25%",
              "alignment": "top-middle",
              "align_text": "left"
            }
          },
